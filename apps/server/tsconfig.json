{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "module": "commonjs",
        "outDir": "dist",
        "moduleResolution": "node",
        "baseUrl": "./",
        "paths": {
            "src/*": ["dist/*"]
        }
    },
    "include": [
        "src/**/*",
        "prisma/seed.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}