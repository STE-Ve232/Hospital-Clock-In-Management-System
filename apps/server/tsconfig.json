{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "module": "commonjs",
        "outDir": "dist",
        "rootDir": "src",
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}